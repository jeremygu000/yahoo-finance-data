# Market Data Service Configuration
# Copy this file to .env and fill in your values

# --- Data Sources ---
FRED_API_KEY=your_fred_api_key_here
TIINGO_API_KEY=your_tiingo_api_key_here
FMP_API_KEY=your_fmp_api_key_here

# --- Provider ---
# Primary provider: yfinance (default), tiingo, fmp
# MARKET_DATA_PROVIDER=yfinance
# Fallback order (comma-separated): tried in order when primary fails
# MARKET_DATA_FALLBACK_CHAIN=yfinance,tiingo,fmp

# --- Storage ---
# MARKET_DATA_DIR=~/.market_data/parquet
# MARKET_DATA_LOG_DIR=~/.market_data/logs

# --- Fetch ---
# MARKET_DATA_LOOKBACK_DAYS=365
# MARKET_DATA_MAX_RETRIES=3

# --- Server ---
# MARKET_DATA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# MARKET_DATA_WS_POLL_INTERVAL=5
# MARKET_DATA_WS_HEARTBEAT_INTERVAL=15
# MARKET_DATA_API_KEY=

# --- Docker ---
# NGINX_PORT=80
# NEXT_PUBLIC_API_URL=http://localhost:80
